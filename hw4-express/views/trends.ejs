<%- include('partials/header') %>

<h1><i class="fas fa-chart-line"></i> Future Trends in Programming</h1>
<p>Emerging technologies and trends shaping the future of software development.</p>

<div class="trends-grid">
    <% trends.forEach(trend => { %>
        <div class="trend-card">
            <h3><%= trend.name %></h3>
            <p><%= trend.description %></p>
            <span class="impact impact-<%= trend.impact.toLowerCase() %>">
                <i class="fas fa-chart-simple"></i> Impact: <%= trend.impact %>
            </span>
        </div>
    <% }); %>
</div>

<!-- Web API Note -->
<div class="api-note-box">
    <i class="fab fa-github"></i>
    <strong>GitHub API Insight:</strong> The most active repositories in 2024 focus on AI tools and developer productivity.
</div>

<%- include('partials/footer') %>