<%- include('partials/header') %>

<h1><i class="fas fa-globe"></i> Welcome to Programming Languages Explorer</h1>

<!-- Display Node Package Data -->
<div class="fact-card">
    <h3><i class="fas fa-lightbulb"></i> Random Programming Fact</h3>
    <p class="fact-text">"<%= randomFact.fact %>"</p>
    <span class="fact-category"><i class="fas fa-tag"></i> <%= randomFact.category %></span>
    <small class="fact-note">📦 Powered by custom Node fact generator</small>
</div>

<!-- Display Web API Data -->
<h2><i class="fab fa-github"></i> Trending Languages from GitHub</h2>
<p class="api-note"><i class="fas fa-cloud-upload-alt"></i> Data from GitHub API - Real repositories with >10,000 stars</p>

<div class="language-grid">
    <% topLanguages.forEach(lang => { %>
        <div class="language-card">
            <div class="language-icon">
                <i class="fas fa-code"></i>
            </div>
            <h3><%= lang.name %></h3>
            <p>Popular repositories: <strong><%= lang.repos %></strong></p>
            <div class="progress-bar">
                <div class="progress" style="width: <%= (lang.repos / topLanguages[0].repos) * 100 %>%"></div>
            </div>
        </div>
    <% }); %>
</div>

<div class="info-section">
    <h2><i class="fas fa-rocket"></i> Why Learn Programming?</h2>
    <div class="features">
        <div class="feature">
            <i class="fas fa-briefcase"></i>
            <h3>High Demand</h3>
            <p>Software developers are among the most sought-after professionals</p>
        </div>
        <div class="feature">
            <i class="fas fa-brain"></i>
            <h3>Problem Solving</h3>
            <p>Develop logical thinking and analytical skills</p>
        </div>
        <div class="feature">
            <i class="fas fa-globe"></i>
            <h3>Remote Work</h3>
            <p>Work from anywhere in the world</p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>