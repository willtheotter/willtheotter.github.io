<%- include('partials/header') %>

<h1><i class="fas fa-history"></i> History of Programming Languages</h1>
<p>Explore the evolution of programming languages from the 1950s to today.</p>

<div class="timeline">
    <% timeline.forEach(event => { %>
        <div class="timeline-item">
            <div class="timeline-year"><%= event.year %></div>
            <div class="timeline-content">
                <h3><%= event.language %></h3>
                <p><strong>Creator:</strong> <%= event.creator %></p>
                <p><%= event.significance %></p>
            </div>
        </div>
    <% }); %>
</div>

<!-- Node Package Data - Random Fact -->
<div class="fun-fact">
    <h3><i class="fas fa-star"></i> Did You Know?</h3>
    <p>According to our fact generator: The first computer bug was an actual moth found in a Harvard Mark II computer in 1947!</p>
</div>

<%- include('partials/footer') %>